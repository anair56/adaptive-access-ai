{
  "manifest_version": 3,
  "name": "TremorSense",
  "version": "2.0.0",
  "description": "AI-powered tremor detection and motor accessibility assistance",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webNavigation"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/voice-navigator.js", "js/content.js"],
      "css": ["css/accessibility.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "css/accessibility.css",
        "css/modern-ui.css",
        "images/tremorsense-logo.png",
        "js/voice-navigator.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "commands": {
    "toggle-accessibility": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "Toggle accessibility mode"
    }
  }
}